# MongoDB
MONGODB_DB=nasoma

# Redis — set automatically by docker-compose; override only for external Redis
REDIS_URL=redis://nasoma-redis:6379

# MinIO Object Storage
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-strong-minio-secret
MINIO_BUCKET=documents

# Auth secrets — must match between client and api
JWT_SECRET=change-me-use-openssl-rand-base64-32
NEXTAUTH_SECRET=change-me-use-openssl-rand-base64-32

# Kokoro TTS sidecar (e.g. a Modal serverless endpoint URL)
KOKORO_URL=https://your-modal-endpoint.modal.run

# AI features (chat, summary, quiz, recap) — required, the API will fail to
# start without these
OPENAI_API_KEY=sk-your-openai-key
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX=me-nasoma-vector-store

# Full HTTPS URL of the app (your domain)
NEXTAUTH_URL=https://me-nasoma.com